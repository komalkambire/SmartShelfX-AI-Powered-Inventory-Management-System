# AI Service Environment Variables

# CORS Configuration
# For development: *
# For production: Backend URL only (AI service doesn't need to accept browser requests)
CORS_ORIGINS=localhost:8080

# Server Configuration
PORT=8000

# Optional: Model configuration (if using external models)
# MODEL_PATH=/path/to/model
# MODEL_VERSION=1.0.0

# Optional: Database for forecast history (future enhancement)
# DATABASE_URL=postgresql://user:password@host:5432/forecasts
