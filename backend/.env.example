# Server Configuration
PORT=8080

# Database Configuration
# IMPORTANT: Rotate these credentials! The previous values were exposed in Git history.
DATABASE_URL=jdbc:mysql://localhost:3306/smartshelfx?createDatabaseIfNotExist=true
DB_USERNAME=root
DB_PASSWORD=your_secure_database_password_here

# JWT Configuration
# IMPORTANT: Generate a new secret! The previous one was exposed in Git history.
# Generate a secure 256-bit key: openssl rand -hex 32
JWT_SECRET=your_new_jwt_secret_key_here_min_256_bits
JWT_EXPIRATION=86400000

# AI Service Configuration
AI_SERVICE_URL=http://localhost:8000

# CORS Configuration
# For development: *
# For production: https://smartshelfx.netlify.app,https://your-other-domain.com
CORS_ALLOWED_ORIGINS=*

# Production Example (Google Cloud Run + Netlify)
# DATABASE_URL=jdbc:mysql://your-cloud-sql-host:3306/smartshelfx
# DB_USERNAME=your_db_user
# DB_PASSWORD=your_secure_password
# JWT_SECRET=your_production_jwt_secret
# AI_SERVICE_URL=https://your-ai-service.run.app
# CORS_ALLOWED_ORIGINS=https://smartshelfx.netlify.app
